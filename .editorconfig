root = true

[*.cs]
indent_size = 4
indent_style = space
csharp_new_line_before_open_brace = all
csharp_space_between_parentheses = false
csharp_space_before_colon_in_inheritance_clause = true
csharp_space_after_colon_in_inheritance_clause = true
csharp_space_around_binary_operators = true
csharp_space_before_comma = false
csharp_space_after_comma = true
csharp_space_before_dot = false
csharp_space_after_dot = false
csharp_space_before_semicolon_in_for_statement = false
csharp_space_after_semicolon_in_for_statement = true
csharp_new_line_before_catch = true
csharp_new_line_before_else = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true
csharp_using_directive_placement = outside_namespace
csharp_prefer_braces = true
csharp_prefer_simple_using_statement = true
csharp_style_expression_bodied_methods = block_body
csharp_style_expression_bodied_constructors = block_body
csharp_style_expression_bodied_properties = block_body
csharp_style_expression_bodied_accessors = block_body
csharp_style_expression_bodied_indexers = block_body
csharp_style_expression_bodied_operators = block_body
csharp_style_expression_bodied_conversions = block_body

# Naming styles
dotnet_naming_rule.interface_names_should_start_with_i.symbols = interfaces
dotnet_naming_rule.interface_names_should_start_with_i.style = interface_style
dotnet_naming_rule.interface_names_should_start_with_i.severity = suggestion

dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_symbols.interfaces.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected

dotnet_naming_style.interface_style.required_prefix = I
dotnet_naming_style.interface_style.capitalization = pascal_case

# Var preferences
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# Nullability
csharp_style_pattern_matching_on_not_null = true:suggestion

# Allman braces
csharp_new_line_before_open_brace = all

# Namespace declarations
csharp_style_namespace_declarations = block_scoped:suggestion

# Using directives placement
file_header_template = unset
csharp_using_directive_placement = outside_namespace:suggestion

# dotnet_style_qualification_for_field = false:suggestion
# dotnet_style_qualification_for_property = false:suggestion
# dotnet_style_qualification_for_method = false:suggestion
# dotnet_style_qualification_for_event = false:suggestion

# Code style
dotnet_style_null_propagation = true:suggestion
dotnet_style_parentheses_in_arithmetic_binary_operators = always_if_needed:suggestion
dotnet_style_parentheses_in_relational_binary_operators = always_if_needed:suggestion
dotnet_style_parentheses_in_other_binary_operators = always_if_needed:suggestion
dotnet_style_prefer_compound_assignment = true:suggestion
dotnet_style_prefer_conditional_expression = true:suggestion
dotnet_style_prefer_inline_out_variable = true:suggestion
dotnet_style_prefer_is_null_check = true:suggestion
dotnet_style_prefer_explicit_tuple_names = true:suggestion
dotnet_style_prefer_auto_properties = true:suggestion
dotnet_style_prefer_expression_bodied_constructors = false:suggestion
dotnet_style_prefer_expression_bodied_methods = false:suggestion
dotnet_style_prefer_expression_bodied_operators = false:suggestion
dotnet_style_prefer_expression_bodied_properties = false:suggestion
dotnet_style_prefer_expression_bodied_accessors = false:suggestion
dotnet_style_prefer_expression_bodied_indexers = false:suggestion
dotnet_style_prefer_expression_bodied_conversions = false:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_object_initializer = true:suggestion
dotnet_style_prefer_system_reflection_metadata_language_version = true:suggestion
dotnet_style_prefer_inferred_anonymous_type_member_names = true:suggestion
dotnet_style_prefer_inferred_tuple_element_names = true:suggestion
dotnet_style_prefer_is_pattern = true:suggestion
dotnet_style_prefer_not_pattern = true:suggestion
dotnet_style_prefer_parameter_null_checking = true:suggestion
dotnet_style_prefer_readonly_structs = true:suggestion
dotnet_style_prefer_static_local_function = true:suggestion
dotnet_style_prefer_string_interpolation = true:suggestion
dotnet_style_prefer_switch_expression = true:suggestion
dotnet_style_prefer_tuple_swap = true:suggestion
dotnet_style_prefer_utf8_string_literals = true:suggestion
dotnet_style_prefer_with_expression = true:suggestion
dotnet_style_require_accessibility_modifiers = for_private_members:suggestion
dotnet_style_readonly_field = true:suggestion

# C# formatting options
csharp_indent_block_contents = true
csharp_indent_braces = false
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_labels = flush_left

# New lines
csharp_new_line_before_catch = true
csharp_new_line_before_else = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true

# Spaces
csharp_space_after_cast = false
csharp_space_after_colon_in_inheritance_clause = true
csharp_space_after_comma = true
csharp_space_after_dot = false
csharp_space_after_keyword_in_control_flow_statements = true
csharp_space_after_semicolon_in_for_statement = true
csharp_space_around_binary_operators = true
csharp_space_around_declaration_statements = true
csharp_space_before_colon_in_inheritance_clause = true
csharp_space_before_comma = false
csharp_space_before_dot = false
csharp_space_before_open_square_brackets = false
csharp_space_before_semicolon_in_for_statement = false
csharp_space_between_empty_anonymous_method_brackets = false
csharp_space_between_empty_brackets = false
csharp_space_between_empty_frequently_used_parentheses = false
csharp_space_between_empty_method_call_parentheses = false
csharp_space_between_empty_method_declaration_parentheses = false
csharp_space_between_parentheses = false
csharp_space_in_binary_operators = one
csharp_space_in_control_flow_statement_parentheses = false
csharp_space_in_type_constraint_parentheses = false

# Wrapping
csharp_preserve_single_line_blocks = true
csharp_preserve_single_line_statements = false
